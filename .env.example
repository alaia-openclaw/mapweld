# Authentication (NextAuth + MongoDB). Copy to `.env.local` for local dev.
# https://next-auth.js.org/configuration/options

MONGODB_URI=
# NextAuth v5 also accepts AUTH_SECRET / AUTH_URL (see https://authjs.dev)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — omit to hide “Continue with Google” on login/register)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend transactional email (optional — welcome email skipped if unset)
# https://resend.com/docs — verify a domain for production; use onboarding@resend.dev only for tests
RESEND_API_KEY=
EMAIL_FROM=
