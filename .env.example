# Authentication (NextAuth + MongoDB). Copy to `.env.local` for local dev.
# https://next-auth.js.org/configuration/options

# --- MongoDB: one URI per environment ----------------------------------------
# The app only reads MONGODB_URI. Use a different value in dev vs prod (never
# commit real URIs or passwords).
#
# Local development (.env.local):
#   - Local MongoDB:
#       MONGODB_URI=mongodb://127.0.0.1:27017/mapweld_dev
#   - Or MongoDB Atlas “dev” cluster / database (recommended if you match prod):
#       MONGODB_URI=mongodb+srv://DEV_USER:DEV_PASSWORD@dev-cluster.xxxxx.mongodb.net/mapweld_dev?retryWrites=true&w=majority
#
# Production (Vercel / Railway / etc. — set in the host’s Environment Variables):
#   - Separate Atlas cluster or same cluster with a different database name:
#       MONGODB_URI=mongodb+srv://PROD_USER:PROD_PASSWORD@prod-cluster.xxxxx.mongodb.net/mapweld_prod?retryWrites=true&w=majority
#
# Tips: use distinct DB names (mapweld_dev vs mapweld_prod) or distinct clusters
# so test accounts and data never mix with production.
MONGODB_URI=
# NextAuth v5 also accepts AUTH_SECRET / AUTH_URL (see https://authjs.dev)
NEXTAUTH_SECRET=
# Dev: http://localhost:3000  |  Prod: https://your-domain.com (must match the URL users open)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (optional — omit to hide “Continue with Google” on login/register)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend transactional email (optional — welcome email skipped if unset)
# https://resend.com/docs — verify mapweld.app (and resend subdomain) in Resend
RESEND_API_KEY=
# Transactional senders (verify each domain in Resend)
EMAIL_FROM_VERIFICATION=MapWeld <noreply@resend.mapweld.app>
EMAIL_FROM_WELCOME=MapWeld <hello@mapweld.app>
EMAIL_FROM_CONTACT=MapWeld <hello@mapweld.app>
# Legacy fallback if a specific FROM is unset
EMAIL_FROM=
